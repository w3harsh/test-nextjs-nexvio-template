# Get your widget public key from https://app.nexvio.ai (Agents → your agent → Integrate).
# Example: pk_xxxxxxxx (leave empty when using "Deploy with Vercel" so Vercel prompts you)
NEXT_PUBLIC_NEXVIO_ID=

# Optional: widget frame URL (default: https://chatwidget.app/frame)
# NEXT_PUBLIC_NEXVIO_WIDGET_FRAME_URL=https://chatwidget.app/frame
